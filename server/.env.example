# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USER:PASS@cluster0.mongodb.net/learning-assistant

# JWT signing secret (use a long random string)
JWT_SECRET=replace-me-with-a-long-random-string

# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Optional override; defaults to gemini-2.5-flash with fallbacks
GEMINI_MODEL=gemini-2.5-flash

# Server config
PORT=5000

# Comma-separated frontend origins allowed to call this API.
# Add your exact Vercel production domain here in Render/Railway/etc.
CORS_ORIGIN=http://localhost:5173,https://e-learning-platform-ashen-eta.vercel.app

# Optional: allow Vercel preview deployments matching e-learning-platform-*.vercel.app
CORS_ALLOW_VERCEL_PREVIEWS=false
